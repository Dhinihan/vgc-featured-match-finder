# Postgres/Neon connection string
DATABASE_URL=

# Secret required by the admin CP import endpoint (x-admin-secret header)
ADMIN_REFRESH_SECRET=

# Optional cache TTLs (seconds) and recent-events window (hours)
RECENT_EVENTS_TTL_SECONDS=600
ACTIVE_ROUND_TTL_SECONDS=60
EVENT_METADATA_TTL_SECONDS=180
RECENT_EVENTS_WINDOW_HOURS=36
